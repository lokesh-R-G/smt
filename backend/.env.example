APP_NAME=SMT Backend API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=smt_db
JWT_SECRET=change-this-to-a-long-random-secret-with-at-least-32-chars
# Backward-compatible key name (optional)
# JWT_SECRET_KEY=change-this-to-a-long-random-secret-with-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASSWORD=app-password
SMTP_FROM_EMAIL=example@gmail.com
SMTP_USE_TLS=true
ADMIN_NOTIFICATION_EMAIL=admin@srimaruthitraders.com
